# ── MedAI Environment Configuration ──────────────────────
# Copy this file to .env and fill in your values

# REQUIRED: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Flask secret keys (change these in production)
SECRET_KEY=medai-super-secret-change-this-in-production
JWT_SECRET_KEY=medai-jwt-secret-change-this-in-production

# Database (SQLite by default, use PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@localhost/medai

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=1
