{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MedAI Flask",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "env": {
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "console": "integratedTerminal"
    }
  ]
}
